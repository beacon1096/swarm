---
# Override of templates/config/kubernetes/components/sops/cluster-secrets.sops.yaml.j2
# adds the locally-introduced ${SECRET_*} variables that aren't part
# of cluster-template's stock list.
#
# Add new entries here as you land them. NEVER inline literal
# credentials in this file — values must come from cluster.yaml via
# `#{ var }#` substitutions, otherwise they land cleartext on disk
# and in git (commit 573ab4b leaked an OAuth client this way before
# this rule was introduced).
apiVersion: v1
kind: Secret
metadata:
  name: cluster-secrets
stringData:
  SECRET_DOMAIN: "#{ cloudflare_domain }#"
  # Tailscale operator OAuth client. Tagged tag:talos-ii-operator so
  # the operator's own tailnet device + ts-* proxy pods land in the
  # talos-ii namespace (was historically tag:k8s-operator).
  SECRET_TAILSCALE_OAUTH_CLIENT_ID: "#{ tailscale_oauth_client_id }#"
  SECRET_TAILSCALE_OAUTH_CLIENT_SECRET: "#{ tailscale_oauth_client_secret }#"
  # matrix-synapse — substituted into helmrelease.yaml's
  # `extraSecrets.oidc_providers[].client_id/client_secret` and
  # `extraSecrets.registration_shared_secret`.
  MATRIX_REGISTRATION_SHARED_SECRET: "#{ matrix_registration_shared_secret }#"
  MATRIX_OIDC_CLIENT_ID: "#{ matrix_oidc_client_id }#"
  MATRIX_OIDC_CLIENT_SECRET: "#{ matrix_oidc_client_secret }#"
  # zot in-cluster — base64('admin:<plaintext password>') for chart's
  # authHeader value, used by kubelet's startup/liveness/readiness
  # probes against the htpasswd-protected mgmt routes (/livez /readyz
  # /startupz). Rotate with kubernetes/apps/registry/zot/app/secret.sops.yaml.
  ZOT_PROBE_AUTH_HEADER: "#{ zot_probe_auth_header }#"
